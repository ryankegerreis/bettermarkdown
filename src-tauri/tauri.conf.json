{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bettermarkdown",
  "version": "0.1.0",
  "identifier": "com.bettermarkdown.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bettermarkdown",
        "width": 1000,
        "height": 720
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A fast, disk-first markdown editor",
    "longDescription": "A fast, disk-first markdown editor with Obsidian-style live preview.",
    "createUpdaterArtifacts": true,
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Default",
        "mimeType": "text/markdown",
        "contentTypes": ["net.daringfireball.markdown"]
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4RDhDN0Q4OUJBN0FCNzkKUldSNXE2ZWIyTWZZV05zVytkT3ZiT0FVM29kdjA1VEgrVHY4NnJKN2xlSTZVMnhUakJ4aDNiWHQK",
      "endpoints": [
        "https://github.com/ryankegerreis/bettermarkdown/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
